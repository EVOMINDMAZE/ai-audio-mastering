# ---- Version control --------------------------------------------------------
# Lockfile IS committed (npm ci needs it, pip doesn't have one in this repo).
*.bak
*.swp
*.swo

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
*.egg-info/
dist/
build/

# ---- Node / frontend -------------------------------------------------------
**/node_modules/
**/dist/
**/.vite/
**/.next/
**/.cache/
**/.parcel-cache/
**/tsconfig.tsbuildinfo

# ---- Editor / OS junk ------------------------------------------------------
.idea/
.vscode/
.DS_Store
Thumbs.db
*.iml

# ---- Local secrets / env ---------------------------------------------------
.env
.env.*
!.env.example
**/.env
**/.env.*

# ---- Spec / planning docs (kept in .trae for local reference only) ---------
.trae/

# ---- Tests are committed (small, useful for CI) --------------------------

# ---- HF Spaces / Docker ----------------------------------------------------
# Exclude build artefacts that the Dockerfile rebuilds
frontend/dist/

# ---- Koyeb -----------------------------------------------------------------
# Defensive: ignore a locally-vendored koyeb CLI binary if it ever ends up in
# the repo. Normally installed via brew / curl install script, not vendored.
/koyeb
/koyeb-cli
koyeb-cli-*
# ---- Test fixtures (binary WAVs — kept on disk, not in git) ----------------
backend/tests/fixtures/*.wav
